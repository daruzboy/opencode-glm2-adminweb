{
  "name": "@digimaestro/adapters",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint .",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "prisma db seed --schema prisma/schema.prisma",
    "db:validate": "prisma validate --schema prisma/schema.prisma"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1083.0",
    "@digimaestro/shared": "workspace:*",
    "@prisma/client": "^6.0.0",
    "basic-ftp": "^6.0.1",
    "bullmq": "^5.79.3",
    "jsonwebtoken": "^9.0.3",
    "sharp": "^0.35.3",
    "ssh2-sftp-client": "^12.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ssh2-sftp-client": "^9.0.6",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0"
  }
}
