// Prisma schema — digimaestro (T-020). SRS §8 (indikatif), Backlog Fase 0 T-020.
// Vendor SDK (@prisma/client) hanya boleh dipakai di packages/adapters (SOLID-D).
// Setiap tabel domain bawa tenantId (NFR-09, ADR-5) + timestamps.
// brandId di Tenant: bantuanpajak.id menumpang platform yg sama di masa depan
// (Backlog §1) — biaya nol sekarang; default "digimaestro".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ───────────────────────────────────────────────────────────────────

enum TenantStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
  ARCHIVED
}

enum UserRole {
  OWNER
  STAFF
}

enum Channel {
  WA
  WEB
  TELEGRAM
}

enum ConversationState {
  ONBOARDING
  INTERVIEW
  BUILDING
  REVIEW
  IDLE
  SUPPORT
}

enum MessageDirection {
  IN
  OUT
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  LOCATION
  INTERACTIVE
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum WebsiteStatus {
  DRAFTING
  PREVIEW_READY
  APPROVED
  PUBLISHED
  SUSPENDED
  ARCHIVED
}

enum RevisionStatus {
  DRAFT
  PREVIEW
  APPROVED
  PUBLISHED
  REJECTED
  // Gerbang review PO (P5): revisi ber-template BARU menunggu review admin di editor-web
  // sebelum pelanggan melihat preview. Template sama = lewat langsung (keputusan PO 2026-07-14).
  PENDING_ADMIN_REVIEW
}

enum AgentJobKind {
  BUILD
  EDIT
  ARTICLE
  CATALOG
  DOMAIN
}

enum AgentJobStatus {
  QUEUED
  RUNNING
  NEEDS_INFO
  DONE
  FAILED
}

// ── Models (T-020: 9 model inti) ────────────────────────────────────────────

model Tenant {
  id        String       @id @default(cuid())
  brandId   String       @default("digimaestro")
  name      String
  slug      String       @unique
  status    TenantStatus @default(TRIALING)
  waNumbers String[]
  planId    String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Kuota TRIAL (keputusan PO 2026-07-12: 100 pesan · 1 situs · 14 hari). Ini PAGAR BIAYA:
  // tiap pesan memanggil LLM berbayar, jadi tenant tanpa kuota = lubang biaya terbuka.
  quotaMessages  Int       @default(100)
  usedMessages   Int       @default(0)
  quotaWebsites  Int       @default(1)
  trialEndsAt    DateTime?
  inviteCodeId   String?
  // Catatan bebas ADMIN tentang konsumen (dashboard 2026-07-15) — beda dari
  // TenantProfile.notes yang diisi bot dari percakapan pelanggan.
  adminNote      String?

  users          User[]
  conversations  Conversation[]
  mediaAssets    MediaAsset[]
  channelBindings ChannelBinding[]
  inviteCode     InviteCode? @relation(fields: [inviteCodeId], references: [id], onDelete: SetNull)
  messages      Message[]
  websites      Website[]
  agentJobs     AgentJob[]
  llmUsages     LlmUsage[]
  profile       TenantProfile?
  adminActings  AdminActing[]
  tickets       Ticket[]
  feedbacks     Feedback[]

  @@index([brandId])
}

// Memori per tenant (permintaan PO 2026-07-15): konteks yang MENGIKAT — nama panggilan
// pelanggan, brief usaha terakhir, catatan preferensi — disuntikkan ke prompt agent tiap
// giliran. Riwayat chat hanya 20 pesan terakhir; tanpa ini, sesi edit berikutnya mulai
// dari nol ("amnesia jangka panjang").
model TenantProfile {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  // Nama panggilan pelanggan (SOP: tanyakan nama dulu) — diisi tool remember_customer.
  customerName String?
  // InterviewBrief terakhir yang berhasil di-build (auto-capture saat build sukses).
  brief        Json?
  // Catatan bebas (preferensi, larangan, gaya) — maksimal N terbaru (dipangkas repo).
  notes        String[] @default([])
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Konsol admin via chat (PO 2026-07-15): chat Telegram ADMIN bisa "bertindak sebagai"
// satu konsumen (tenant) — build/review/preview/publish berjalan atas nama tenant itu,
// semua notifikasi mendarat di chat admin. Satu baris per chat admin (praktis: satu).
// Tiketing sederhana (dashboard admin, PO 2026-07-15): pekerjaan per konsumen yang
// perlu ditindaklanjuti manusia. Status string longgar (OPEN|IN_PROGRESS|DONE) — enum
// DB dihindari agar menambah status tak butuh migrasi.
model Ticket {
  id        String   @id @default(cuid())
  tenantId  String
  subject   String
  body      String?
  // Topik (PO 2026-07-15): konten|tampilan|ganti-tema|fitur|akun|gangguan|teknis —
  // diklasifikasikan bot (tool create_ticket) atau dipilih admin. String longgar
  // (bukan enum DB) agar menambah topik tak butuh migrasi.
  topic     String?
  // normal|tinggi — daftar "segera dikerjakan" di dashboard.
  priority  String   @default("normal")
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

// Keluhan & saran (dashboard admin): dicatat bot via tool record_feedback saat pelanggan
// menyampaikan keluhan/saran di chat, atau manual dari dashboard.
model Feedback {
  id         String    @id @default(cuid())
  tenantId   String
  // 'keluhan' | 'saran' (string longgar, alasan sama dgn Ticket.status).
  kind       String
  text       String
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model AdminActing {
  chatId    String   @id
  tenantId  String
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  role      UserRole
  name      String
  phone     String?
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Conversation {
  id          String            @id @default(cuid())
  tenantId    String
  channel     Channel
  // Id chat di sisi penyedia kanal (Telegram chat_id; nomor WA). NULL untuk WEB.
  externalId  String?
  state       ConversationState @default(ONBOARDING)
  escalatedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([tenantId, channel, externalId])
  @@index([tenantId])
}

model Message {
  id             String          @id @default(cuid())
  tenantId       String
  conversationId String
  direction      MessageDirection
  type           MessageType
  text           String?
  mediaId        String?
  providerMsgId  String          @unique
  status         MessageStatus   @default(QUEUED)
  createdAt      DateTime        @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([conversationId])
}

model Website {
  id                  String        @id @default(cuid())
  tenantId            String        @unique
  slug                String        @unique
  status              WebsiteStatus @default(DRAFTING)
  publishedRevisionId String?
  themeId             String?
  // P5: template yang SUDAH lolos review PO untuk tenant ini. Aturan gerbang O(1):
  // revisi.templateId != approvedTemplateId → wajib review admin (null = build pertama).
  approvedTemplateId  String?
  deploymentTargetId  String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  revisions Revision[]

  @@index([tenantId])
}

// T-033: media dari pelanggan (foto di chat) → dioptimasi & disimpan; dipakai galeri situs.
// Self-serve (langkah #6): pemetaan chat kanal → tenant. MENGGANTIKAN allowlist env
// (TELEGRAM_ALLOWLIST) yang harus disunting manual tiap pelanggan baru — mustahil untuk
// self-serve. Env allowlist tetap didukung sebagai bootstrap/admin.
model ChannelBinding {
  id         String   @id @default(cuid())
  tenantId   String
  channel    Channel
  // chat_id Telegram / nomor WA.
  externalId String
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Satu chat = satu tenant. Chat yang sama tak bisa dipetakan ke dua tenant.
  @@unique([channel, externalId])
  @@index([tenantId])
}

// Kode undangan (keputusan PO 2026-07-12): self-serve TAPI tidak terbuka untuk siapa saja.
// Tanpa gerbang ini, setiap orang iseng yang menemukan bot langsung membakar token LLM
// (~$0.0034/pesan). Kode bisa dicabut kapan saja tanpa deploy.
model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  // 0 = tak terbatas.
  maxUses   Int       @default(1)
  usedCount Int       @default(0)
  expiresAt DateTime?
  active    Boolean   @default(true)
  note      String?
  createdAt DateTime  @default(now())

  redemptions Tenant[]
}

model MediaAsset {
  id             String   @id @default(cuid())
  tenantId       String
  // file_id penyedia kanal → dedup: foto sama tak diunduh & diproses ulang.
  providerFileId String
  storageKey     String
  url            String
  contentType    String
  width          Int
  height         Int
  sizeBytes      Int
  // P6 (gambar stok): atribusi WAJIB disimpan saat foto berasal dari Unsplash/Pexels —
  // syarat lisensi keduanya (foto di-download & di-rehost, bukan hotlink). Null = foto
  // kiriman pelanggan sendiri.
  sourceProvider String?
  sourceUrl      String?
  authorName     String?
  authorUrl      String?
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, providerFileId])
  @@index([tenantId])
}

// P3: registry template Mobirise. Baris = folder di TEMPLATES_DIR (satu folder yang sama
// juga dilayani editor-web) — diindeks `pnpm templates:index`, BUKAN sumber kebenaran;
// folder-lah sumbernya (template di-gitignore: lisensi). TIDAK ber-tenantId: katalog
// bersama seluruh platform, bukan data pelanggan.
model Template {
  id            String   @id
  name          String
  description   String
  // Jenis usaha yang cocok (mis. "kuliner","jasa","bengkel") — filter shortlist AI
  // sebelum LLM memilih; ratusan template tak mungkin dimuat semua ke prompt.
  businessTypes String[]
  tags          String[]
  // Ringkasan slot hasil derive indexer (jumlah halaman/blok/slot teks/gambar) —
  // bahan ringkas prompt pemilihan.
  slotSummary   Json
  coverPath     String?
  active        Boolean  @default(true)
  // Hash isi project.mobirise → indexer tahu folder berubah tanpa membandingkan isi penuh.
  sourceHash    String
  indexedAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Revision {
  id        String         @id @default(cuid())
  websiteId String
  number    Int
  siteDoc   Json
  summary   String?
  status    RevisionStatus @default(DRAFT)
  createdBy String
  // P2 dual-mode: 'sections-v1' (renderer lama sites-kit) | 'mobirise-v1' (engine Mobirise).
  // Diskriminator per-REVISI, bukan per-Website: situs lama tetap ter-render selamanya,
  // dan sebuah tenant "bermigrasi" cukup dengan mendapat revisi mobirise baru.
  renderEngine String @default("sections-v1")
  // mobirise-v1: template asal (id folder di TEMPLATES_DIR) — dasar aturan gerbang review
  // ("template BARU untuk tenant ini?") + resolusi aset saat publish.
  templateId String?
  // P5: Project editor-web hasil handoff (korelasi review PO). Null = tak/belum di-handoff.
  editorProjectId String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@unique([websiteId, number])
  @@index([websiteId])
}

model AgentJob {
  id           String         @id @default(cuid())
  tenantId     String
  kind         AgentJobKind
  status       AgentJobStatus @default(QUEUED)
  input        Json
  output       Json?
  error        String?
  attempts     Int            @default(0)
  tokenIn      Int            @default(0)
  tokenOut     Int            @default(0)
  costEstimate Decimal        @default(0) @db.Decimal(12, 6)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  llmUsage LlmUsage[]

  @@index([tenantId])
  @@index([status])
}

model LlmUsage {
  id        String   @id @default(cuid())
  tenantId  String
  jobId     String?
  provider  String
  task      String
  tokenIn   Int      @default(0)
  tokenOut  Int      @default(0)
  cost      Decimal  @default(0) @db.Decimal(12, 6)
  createdAt DateTime @default(now())

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job    AgentJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([jobId])
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     String
  tenantId  String?
  action    String
  meta      Json
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([actor])
}
