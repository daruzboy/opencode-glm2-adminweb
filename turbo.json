{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": [
    "tsconfig.base.json",
    "eslint.config.js",
    "vitest.config.ts",
    "turbo.json",
    "pnpm-workspace.yaml"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "test": {
      "dependsOn": [
        "build"
      ],
      "env": [
        "DATABASE_URL",
        "RUN_INTEGRATION_TESTS"
      ]
    },
    "lint": {}
  }
}
