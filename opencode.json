{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["decision.md", "context.md", "AGENTS.md", "docs/qa/README.md"],
  "mcp": {
    "TestSprite": {
      "type": "local",
      "command": ["npx", "-y", "@testsprite/testsprite-mcp@latest"],
      "enabled": true,
      "environment": {
        "API_KEY": "{env:TESTSPRITE_API_KEY}"
      }
    }
  },
  "permission": {
    "bash": {
      "testsprite *": "allow",
      "pnpm *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "tsc *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "git checkout *": "allow",
      "git add *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "rg *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "mkdir *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "touch *": "allow",
      "echo *": "allow",
      "*": "ask"
    },
    "edit": "allow",
    "write": "allow"
  },
  "references": {
    "spec": {
      "path": "./doc",
      "description": "Product spec (BRD/PRD/FRD/SRS markdown). The PRD.md is the canonical spec TestSprite verifies against."
    }
  }
}
