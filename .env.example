# Template env digimaestro — JANGAN isi nilai asli di repo.
# Produksi: rahasia via secret manager / environment VPS, bukan berkas .env.
# Dev lokal: salin ke .env lalu isi. Acuan: DevSetup dok. 09 §6, SRS §3.3.

# --- Inti ---
APP_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/digimaestro
REDIS_URL=redis://localhost:6379

# --- LLM (via LlmPort; provider dapat ditukar, SRS §5.1) ---
DIGIMAESTRO_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=
GLM_API_KEY=
GLM_MODEL=glm-4.5
GLM_BASE_URL=

# --- QA otomatis (TestSprite MCP) ---
TESTSPRITE_API_KEY=

# --- WhatsApp Cloud API (FR-CHN-*) ---
WABA_PHONE_NUMBER_ID=
WABA_TOKEN=
WABA_VERIFY_TOKEN=
WABA_APP_SECRET=

# --- Deploy situs klien (DeployPort / HostingControlPort, SRS §9.1) ---
CPANEL_HOST=
CPANEL_UAPI_TOKEN=
DEPLOY_SSH_KEY_PATH=

# --- Billing (FR-BIL-*) ---
XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=

# --- Object storage (media + build artifact) ---
# Default: MinIO self-host (profil compose `storage`). Host di jaringan compose = `minio`;
# dari luar VPS = http://<ip-vps>:9000. Kredensial = MINIO_ROOT_* (bagian Docker Compose).
#   S3_ENDPOINT=http://minio:9000   S3_KEY=<MINIO_ROOT_USER>   S3_SECRET=<MINIO_ROOT_PASSWORD>
S3_ENDPOINT=http://minio:9000
S3_BUCKET=digimaestro-artifacts
S3_KEY=
S3_SECRET=
# S3_REGION opsional (default us-east-1; MinIO abaikan). Bila S3_KEY/S3_SECRET kosong,
# worker publish memakai artifact store lokal-FS (dev): PUBLISH_ARTIFACT_DIR.

# --- Publish pipeline (T-063, worker BullMQ consumer) ---
# Fallback lokal-FS saat tanpa S3/cPanel (dev). Deploy nyata cPanel rsync/SSH menyusul.
PUBLISH_ARTIFACT_DIR=./data/artifacts
PUBLISH_DOCROOT_BASE=./data/www
PUBLISH_BASE_DOMAIN=digimaestro.id

# --- Deploy cPanel via SFTP/SSH (T-063, FR-PUB-004/009) ---
# Bila CPANEL_SFTP_HOST + CPANEL_SFTP_USER diisi, worker deploy ke shared hosting via SFTP
# (deploy bersih: upload + hapus file usang). Auth: password ATAU private key (lebih aman).
# Docroot per subdomain via template ({slug} diganti slug situs).
CPANEL_SFTP_HOST=
CPANEL_SFTP_PORT=22
CPANEL_SFTP_USER=
CPANEL_SFTP_PASSWORD=
CPANEL_SFTP_KEY_PATH=
CPANEL_SFTP_PASSPHRASE=
CPANEL_DOCROOT_TEMPLATE=public_html/{slug}

# Fallback FTP/FTPS untuk host tanpa SSH (mis. shared hosting Rumahweb). Dipakai bila
# CPANEL_SFTP_* kosong & CPANEL_FTP_HOST+USER diisi. Default FTPS eksplisit (secure=true).
# CPANEL_FTP_REJECT_UNAUTHORIZED=false bila sertifikat TLS mismatch (host via IP).
CPANEL_FTP_HOST=
CPANEL_FTP_PORT=21
CPANEL_FTP_USER=
CPANEL_FTP_PASSWORD=
CPANEL_FTP_SECURE=true
CPANEL_FTP_REJECT_UNAUTHORIZED=true

# Provisioning subdomain via cPanel UAPI (T-063, FR-PUB-004b). Bila HOST+USER+(TOKEN|PASSWORD)
# diisi, worker membuat <slug>.<rootDomain> sebelum deploy (idempoten). Auth: API token
# (preferensi) ATAU password login cPanel (Basic auth, fallback host tanpa menu API token).
CPANEL_UAPI_HOST=
CPANEL_UAPI_PORT=2083
CPANEL_UAPI_USER=
CPANEL_UAPI_TOKEN=
CPANEL_UAPI_PASSWORD=

# --- Preview draft (T-064, FR-PUB-001) ---
# Rahasia server untuk token preview stateless (HMAC-SHA256 atas revisionId). Bila kosong,
# rute /api/preview/:revisionId TIDAK diaktifkan. Rotasi = mencabut semua URL preview lama.
PREVIEW_TOKEN_SECRET=

# --- Autentikasi tenant (T-002auth, NFR-07) ---
# JWT_SECRET wajib diisi untuk mengaktifkan autentikasi (POST /api/auth/token + route guard).
# Bila kosong: server jalan tanpa auth (resolusi tenant via x-tenant-id header, DEV ONLY).
# AUTH_DISABLED=1 → fallback ke header x-tenant-id (backward-compat dev; TIDAK AMAN produksi).
JWT_SECRET=
AUTH_DISABLED=

# --- Analytics & otomasi ops ---
UMAMI_URL=
N8N_WEBHOOK_TOKEN=

# --- Docker Compose (T-012) ---
# Di dalam jaringan compose, host DB/Redis = nama service (postgres/redis), BUKAN localhost:
#   DATABASE_URL=postgresql://postgres:postgres@postgres:5432/digimaestro
#   REDIS_URL=redis://redis:6379
# Semua di bawah punya default dev di compose; override untuk prod.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=digimaestro
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=3000
NODE_ENV=production
# Rahasia service ops — WAJIB diganti di prod:
N8N_ENCRYPTION_KEY=
N8N_PORT=5678
UMAMI_APP_SECRET=
UMAMI_PORT=3001
TZ=Asia/Jakarta
# MinIO object storage (profil `storage`). ROOT_* = kredensial S3 (S3_KEY/S3_SECRET).
# WAJIB ganti password di prod (min. 8 char).
MINIO_ROOT_USER=digimaestro
MINIO_ROOT_PASSWORD=digimaestro-dev-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
