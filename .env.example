# Template env digimaestro — JANGAN isi nilai asli di repo.
# Produksi: rahasia via secret manager / environment VPS, bukan berkas .env.
# Dev lokal: salin ke .env lalu isi. Acuan: DevSetup dok. 09 §6, SRS §3.3.

# --- Inti ---
APP_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/digimaestro
REDIS_URL=redis://localhost:6379

# --- LLM (via LlmPort; provider dapat ditukar, SRS §5.1) ---
DIGIMAESTRO_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=
GLM_API_KEY=
GLM_MODEL=glm-4.5
GLM_BASE_URL=

# --- QA otomatis (TestSprite MCP) ---
TESTSPRITE_API_KEY=

# --- WhatsApp Cloud API (FR-CHN-*) ---
WABA_PHONE_NUMBER_ID=
WABA_TOKEN=
WABA_VERIFY_TOKEN=
WABA_APP_SECRET=

# --- Deploy situs klien (DeployPort / HostingControlPort, SRS §9.1) ---
CPANEL_HOST=
CPANEL_UAPI_TOKEN=
DEPLOY_SSH_KEY_PATH=

# --- Billing (FR-BIL-*) ---
XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=

# --- Object storage (media + build artifact) ---
# Default: MinIO self-host (profil compose `storage`). Host di jaringan compose = `minio`;
# dari luar VPS = http://<ip-vps>:9000. Kredensial = MINIO_ROOT_* (bagian Docker Compose).
#   S3_ENDPOINT=http://minio:9000   S3_KEY=<MINIO_ROOT_USER>   S3_SECRET=<MINIO_ROOT_PASSWORD>
S3_ENDPOINT=http://minio:9000
S3_BUCKET=digimaestro-artifacts
S3_KEY=
S3_SECRET=
# S3_REGION opsional (default us-east-1; MinIO abaikan). Bila S3_KEY/S3_SECRET kosong,
# worker publish memakai artifact store lokal-FS (dev): PUBLISH_ARTIFACT_DIR.

# --- Publish pipeline (T-063, worker BullMQ consumer) ---
# Fallback lokal-FS saat tanpa S3/cPanel (dev). Deploy nyata cPanel rsync/SSH menyusul.
PUBLISH_ARTIFACT_DIR=./data/artifacts
PUBLISH_DOCROOT_BASE=./data/www
PUBLISH_BASE_DOMAIN=digimaestro.id

# --- Deploy cPanel via SFTP/SSH (T-063, FR-PUB-004/009) ---
# Bila CPANEL_SFTP_HOST + CPANEL_SFTP_USER diisi, worker deploy ke shared hosting via SFTP
# (deploy bersih: upload + hapus file usang). Auth: password ATAU private key (lebih aman).
# Docroot per subdomain via template ({slug} diganti slug situs).
CPANEL_SFTP_HOST=
CPANEL_SFTP_PORT=22
CPANEL_SFTP_USER=
CPANEL_SFTP_PASSWORD=
CPANEL_SFTP_KEY_PATH=
CPANEL_SFTP_PASSPHRASE=
CPANEL_DOCROOT_TEMPLATE=public_html/{slug}

# Fallback FTP/FTPS untuk host tanpa SSH (mis. shared hosting Rumahweb). Dipakai bila
# CPANEL_SFTP_* kosong & CPANEL_FTP_HOST+USER diisi. Default FTPS eksplisit (secure=true).
# CPANEL_FTP_REJECT_UNAUTHORIZED=false bila sertifikat TLS mismatch (host via IP).
CPANEL_FTP_HOST=
CPANEL_FTP_PORT=21
CPANEL_FTP_USER=
CPANEL_FTP_PASSWORD=
CPANEL_FTP_SECURE=true
CPANEL_FTP_REJECT_UNAUTHORIZED=true

# Provisioning subdomain via cPanel UAPI (T-063, FR-PUB-004b). Bila HOST+USER+(TOKEN|PASSWORD)
# diisi, worker membuat <slug>.<rootDomain> sebelum deploy (idempoten). Auth: API token
# (preferensi) ATAU password login cPanel (Basic auth, fallback host tanpa menu API token).
CPANEL_UAPI_HOST=
CPANEL_UAPI_PORT=2083
CPANEL_UAPI_USER=
CPANEL_UAPI_TOKEN=
CPANEL_UAPI_PASSWORD=

# --- Preview draft (T-064, FR-PUB-001) ---
# Rahasia server untuk token preview stateless (HMAC-SHA256 atas revisionId). Bila kosong,
# rute /api/preview/:revisionId TIDAK diaktifkan. Rotasi = mencabut semua URL preview lama.
PREVIEW_TOKEN_SECRET=

# --- Autentikasi tenant (T-002auth, NFR-07) ---
# JWT_SECRET wajib diisi untuk mengaktifkan auth: rute chat/publish menuntut Bearer token JWT.
# Bila kosong: server jalan tanpa auth (resolusi tenant via x-tenant-id header, DEV ONLY).
# AUTH_DISABLED=1 → izinkan fallback x-tenant-id meski JWT aktif (backward-compat dev; TIDAK AMAN produksi).
# AUTH_DEV_TOKEN=1 → pasang endpoint dev POST /api/auth/token (cetak token dari slug TANPA kredensial).
#   JANGAN diisi di produksi — endpoint ini bypass auth. Default kosong = endpoint tak terpasang.
JWT_SECRET=
AUTH_DISABLED=
AUTH_DEV_TOKEN=

# --- Analytics & otomasi ops ---
UMAMI_URL=
N8N_WEBHOOK_TOKEN=

# --- Docker Compose (T-012) ---
# Di dalam jaringan compose, host DB/Redis = nama service (postgres/redis), BUKAN localhost:
#   DATABASE_URL=postgresql://postgres:postgres@postgres:5432/digimaestro
#   REDIS_URL=redis://redis:6379
# Semua di bawah punya default dev di compose; override untuk prod.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=digimaestro
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=3000
NODE_ENV=production
# Rahasia service ops — WAJIB diganti di prod:
N8N_ENCRYPTION_KEY=
N8N_PORT=5678
UMAMI_APP_SECRET=
UMAMI_PORT=3001
TZ=Asia/Jakarta
# MinIO object storage (profil `storage`). ROOT_* = kredensial S3 (S3_KEY/S3_SECRET).
# WAJIB ganti password di prod (min. 8 char).
MINIO_ROOT_USER=digimaestro
MINIO_ROOT_PASSWORD=digimaestro-dev-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Kanal Telegram (T-030tg; rencana B — WABA diparkir menunggu verifikasi Meta) ──
# Token bot dari @BotFather. RAHASIA: pemegang token bisa menyamar jadi bot ini.
# Worker butuh ini untuk MENGIRIM balasan; kosong → konsumen 'chat-inbound' tidak menyala.
TELEGRAM_BOT_TOKEN=
# Secret token webhook: didaftarkan ke Telegram via setWebhook(secret_token=...), lalu
# dikirim balik Telegram di header X-Telegram-Bot-Api-Secret-Token pada tiap update.
# Endpoint webhook publik → ini satu-satunya bukti pemanggilnya benar Telegram.
# Kosong → rute webhook TIDAK dipasang sama sekali. Bangkitkan: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
# Allowlist chat → tenant: "<chat_id>:<tenantId>[,<chat_id>:<tenantId>...]"
# Bot Telegram terbuka: siapa pun bisa mengirim pesan. Hanya chat di daftar ini yang
# dilayani; chat asing ditolak SEBELUM LLM dipanggil (gerbang biaya token).
# Kosong → semua chat ditolak. Dapatkan chat_id: kirim pesan ke bot, lalu getUpdates.
TELEGRAM_ALLOWLIST=

# ── Approval via tombol chat (T-031tg) ────────────────────────────────────────
# Tombol "Setuju & publish" mengantre job publish (BRU-02) → worker butuh REDIS_URL.
# Tautan preview di pesan approval butuh kedua var di bawah; tanpa itu pesan tetap
# terkirim, hanya tanpa tautan.
PUBLIC_API_URL=https://api.digimaestro.id
# Rate limit pesan keluar per chat/tenant (menahan banjir & 429 Telegram).
# Default: 20 pesan / 60000 ms. CATATAN: state per-proses — dengan >1 replika worker,
# batas efektif = N × limit (Fase 0 = 1 worker).
CHANNEL_RATE_LIMIT=20
CHANNEL_RATE_WINDOW_MS=60000

# ── Bentuk URL situs klien (ADR-13) ───────────────────────────────────────────
# 'path'      → https://<domain>/<slug>/   (Fase 0; TANPA cPanel UAPI & tanpa DNS baru)
# 'subdomain' → https://<slug>.<domain>    (FR-PUB-004b; butuh CPANEL_UAPI_* + AutoSSL)
# Default 'subdomain'. Nilai tak dikenal → subdomain (bentuk URL produk tak boleh berubah
# diam-diam karena typo).
PUBLISH_URL_MODE=path

# CATATAN deploy Rumahweb (shared hosting):
# - CPANEL_FTP_HOST harus NAMA SERVER (mis. cikapundung.iixcp.rumahweb.net), BUKAN domain:
#   sertifikat TLS atas nama server, sehingga memakai domain → cert mismatch. Jangan
#   dijawab dengan CPANEL_FTP_REJECT_UNAUTHORIZED=false — itu mengirim password lewat
#   koneksi yang tak terverifikasi.
# - Akun FTP deploy di-chroot ke DOCUMENT ROOT → CPANEL_DOCROOT_TEMPLATE={slug}
#   (bukan public_html/{slug}, yang akan mendarat di public_html/public_html/...).

# ── Gerbang biaya pesan MASUK (P0 audit Telegram; audit 2026-07-16: juga web chat api) ──
# Batas pesan masuk per tenant, dipakai worker (Telegram) DAN api (web chat WS). Ditegakkan
# SEBELUM LLM dipanggil — rate limit pesan KELUAR (CHANNEL_RATE_*) TIDAK melindungi anggaran
# token, karena LLM sudah terlanjur dipanggil saat balasan ditahan. State di Redis → tetap
# benar saat diskalakan >1 replika. Tanpa REDIS_URL → gerbang tidak aktif (bot tetap jalan).
INBOUND_RATE_LIMIT=15
INBOUND_RATE_WINDOW_MS=60000

# ── Batas waktu job chat (P0 — insiden worker beku 2026-07-12) ───────────────
# Batas keras SATU job chat-inbound. Job yang menggantung (mis. perintah Redis mengantre
# tanpa reject pada koneksi maxRetriesPerRequest:null) dipaksa GAGAL → retry BullMQ → alert
# T-070 saat retry habis. Tanpa ini, dua job macet membekukan seluruh worker (concurrency 2)
# TANPA satu pun alert. Default 300000 (5 mnt) — di atas build LLM terlama yang sah.
CHAT_JOB_TIMEOUT_MS=300000

# ── Template Mobirise (P2 — engine mobirise-v1) ──────────────────────────────
# Root folder template Mobirise: berisi <templateId>/project.mobirise + index.html +
# assets/ (+ template.json untuk registry P3). SATU folder yang sama dengan yang dilayani
# editor-web (apps/editor/public/templates) — di-mount read-only ke kontainer glm2.
# Kosong → builder mobirise tak terpasang; revisi mobirise-v1 gagal dengan pesan jelas.
# TEMPLATES_DIR=/opt/dig/projects/editor-web/apps/editor/public/templates

# ── Gerbang review PO (P5) ────────────────────────────────────────────────────
# Situs AI ber-template BARU direview PO di editor-web dulu (dua gerbang; pelanggan tetap
# pemegang akhir). REVIEW_GATE=1 + kredensial editor-web lengkap → aktif; kurang satu →
# build template langsung ke pelanggan (alur P4 murni).
# REVIEW_GATE=1
# EDITOR_WEB_API_URL=http://127.0.0.1:5181     # API editor-web (POST /internal/handoff)
# EDITOR_WEB_APP_URL=http://127.0.0.1:5180     # UI editor (tautan di alert PO)
# HANDOFF_SERVICE_TOKEN=                        # token glm2 → editor-web (samakan di editor-web)
# REVIEW_CALLBACK_TOKEN=                        # token editor-web → glm2 (rute /api/internal/review/complete)

# ── Gambar stok (P6) ──────────────────────────────────────────────────────────
# Slot gambar tanpa foto pelanggan diisi foto stok: LLM menulis kueri (bhs Inggris) →
# foto DI-DOWNLOAD & DI-REHOST ke hosting (bukan hotlink; syarat lisensi) + atribusi
# tercatat di MediaAsset. Urutan: Unsplash dulu, Pexels fallback. Tanpa key → slot
# gambar hanya foto pelanggan/bawaan template. Butuh kredensial CPANEL_FTP_* di atas.
# UNSPLASH_ACCESS_KEY=                          # unsplash.com/developers (demo: 50 req/jam)
# PEXELS_API_KEY=                               # pexels.com/api

# ── SOP pelayanan (dokumen pegangan bot) ─────────────────────────────────────
# File markdown berisi SOP melayani pelanggan (tanya nama dulu, urutan wawancara,
# gaya bahasa, batasan janji). Disunting PO kapan saja — dibaca ulang otomatis saat
# file berubah, TANPA restart. Contoh: docs/sop-pelayanan.example.md
# SOP_PATH=/sop/sop-pelayanan.md
# SOP khusus percakapan chat ADMIN (konsol multi-konsumen). Contoh: docs/sop-admin.example.md
# SOP_ADMIN_PATH=/sop/sop-admin.md

# ── Konsol admin /konsumen (kelola banyak konsumen dari chat admin) ──────────
# Chat yang boleh memakai konsol. Default: ALERT_TELEGRAM_CHAT_ID. Perintah:
# /konsumen daftar | baru <nama> | pilih <slug> | siapa | selesai
# ADMIN_TELEGRAM_CHAT_ID=

# ── Dashboard admin (browser, jaringan tailnet) ──────────────────────────────
# http://<ip-vps>:3000/admin — kelola konsumen (trial/kuota/status), tiket, keluhan &
# saran (dicatat bot via record_feedback), token & biaya (T-082), kinerja VPS.
# Tanpa token ini seluruh rute dashboard TIDAK terpasang (fail-closed).
# ADMIN_DASHBOARD_TOKEN=

# ── Harga token LLM (T-082 — laporan biaya AI) ───────────────────────────────
# USD per 1 JUTA token. WAJIB diisi agar laporan biaya bermakna; 0 = "belum dikonfigurasi"
# (laporan menampilkan token apa adanya + menandai biaya belum bisa dihitung — BUKAN $0).
# Harga TIDAK di-hardcode di kode: ia berubah & beda per model, dan salah menebak =
# laporan yang menyesatkan. Cek harga aktual di dashboard provider.
# Harga resmi DeepSeek (docs, diverifikasi 2026-07-11):
#   deepseek-v4-pro  : input (cache-miss) 0.435 · output 0.87
#   deepseek-v4-flash: input (cache-miss) 0.14  · output 0.28
# CATATAN: konstanta hardcoded LAMA di adapter (0.14/0.28) ternyata harga v4-FLASH — kalau
# dipakai untuk v4-pro, biaya tercatat ~3x LEBIH KECIL dari sebenarnya. Karena itu harga
# hidup di env, bukan di kode.
LLM_PRICE_INPUT_PER_1M=0.435
LLM_PRICE_OUTPUT_PER_1M=0.87
# Tenant yang boleh melihat laporan LINTAS-tenant (GET /api/admin/usage). Kosong → rute
# admin TIDAK dipasang sama sekali (fail-closed).
ADMIN_TENANT_ID=

# ── Backup Postgres (T-073) ──────────────────────────────────────────────────
# Dump lokal harian + retensi. Off-site OPSIONAL & WAJIB TERENKRIPSI: akun FTP di-chroot ke
# document root → apa pun yang diunggah BISA DIAKSES PUBLIK. Dump mentah di sana =
# membocorkan seluruh data pelanggan. Enkripsi = pertahanan utama (.htaccess hanya lapis 2).
BACKUP_DIR=/opt/containers/glm2/backups
BACKUP_KEEP_DAYS=14
# Kosong → off-site DILEWATI (hanya backup lokal). Simpan passphrase di password manager,
# BUKAN di VPS yang sama dengan backup-nya — kalau VPS hilang bersama passphrase, salinan
# off-site jadi sampah terenkripsi.
BACKUP_OFFSITE_PASSPHRASE=
BACKUP_REMOTE_DIR=_backups

# Off-site ke GOOGLE DRIVE via rclone (dipilih PO 2026-07-12: TANPA enkripsi).
# Kosong → dilewati. Butuh `rclone config` sekali (token OAuth Drive PO).
# ⚠️ Folder Drive ini berisi DATA PELANGGAN MENTAH (percakapan, kontak) — JANGAN di-share.
# Kenapa rclone & bukan unggah manual/perantara: cron harus mengunggah SENDIRI tiap malam.
# Backup yang butuh manusia untuk menyalinnya bukan backup otomatis — ia berhenti diam-diam
# pada hari pertama tak ada yang menjalankannya.
BACKUP_GDRIVE_REMOTE=
BACKUP_GDRIVE_DIR=glm2-backups
BACKUP_GDRIVE_KEEP_DAYS=30

# ── Alert operasional (T-070, ADR-7) ─────────────────────────────────────────
# Kegagalan selama ini HANYA masuk log → tak seorang pun tahu bot mati / situs gagal terbit.
# Telegram = jalur UTAMA (hidup di LUAR infrastruktur kita → tetap ada saat platform sekarat).
# Webhook (n8n) = tambahan opsional untuk integrasi lanjutan.
# Kosong → alert tidak aktif.
ALERT_TELEGRAM_CHAT_ID=
ALERT_WEBHOOK_URL=
# Peredam: satu masalah tak boleh jadi ratusan notifikasi (PO akan mematikan alert berisik,
# dan alert yang dimatikan = tidak ada alert). Default 15 menit per jenis masalah.
ALERT_COOLDOWN_MS=900000

# ── Self-serve onboarding + kuota (langkah #6 roadmap §7) ────────────────────
# SELFSERVE_ENABLED=1 → chat yang BELUM dikenal boleh MENDAFTAR dgn kode undangan.
# Nonaktif (default) → hanya TELEGRAM_ALLOWLIST (allowlist env) yang dilayani.
#
# Kenapa kode undangan & bukan terbuka penuh (keputusan PO 2026-07-12): tiap pesan memanggil
# LLM berbayar (~$0.0034 terukur di produksi). Tanpa gerbang, orang iseng yang menemukan bot
# langsung membakar token — 100 orang × 20 pesan ≈ $6.8 hangus tanpa satu pun jadi pelanggan.
SELFSERVE_ENABLED=0
# Kuota TRIAL per tenant baru (PO: 100 pesan · 1 situs · 14 hari ≈ maks $0.36/tenant).
# Ini PAGAR BIAYA: rate limit menahan BANJIR, kuota menahan TOTAL. Keduanya perlu — 100 pesan
# pelan-pelan menghabiskan anggaran yang sama dengan 100 pesan sekaligus.
TRIAL_QUOTA_MESSAGES=100
TRIAL_QUOTA_WEBSITES=1
TRIAL_DAYS=14
