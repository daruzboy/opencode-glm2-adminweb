{
  "name": "digimaestro",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "digimaestro.id — Platform website builder berbasis chatbot & agentic AI (monorepo).",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run build",
    "templates:index": "turbo run build --filter=@digimaestro/adapters && node packages/adapters/dist/templates/index-templates-cli.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
